1. 初始化目录
把 your_name 改成实际用户名：
export FUNASR_ROOT=/cache/ma-user/your_name/funasr

mkdir -p $FUNASR_ROOT/{envs,pkgs,pip-cache,tmp,models,cache,outputs,audios,logs}

export TMPDIR=$FUNASR_ROOT/tmp
export PIP_CACHE_DIR=$FUNASR_ROOT/pip-cache
export CONDA_PKGS_DIRS=$FUNASR_ROOT/pkgs

export MODELSCOPE_CACHE=$FUNASR_ROOT/cache/modelscope
export HF_HOME=$FUNASR_ROOT/cache/huggingface
export TORCH_HOME=$FUNASR_ROOT/cache/torch
export XDG_CACHE_HOME=$FUNASR_ROOT/cache/xdg
export TORCH_EXTENSIONS_DIR=$FUNASR_ROOT/cache/torch-extensions
export TRITON_CACHE_DIR=$FUNASR_ROOT/cache/triton

# 防止误用 ~/.local 中的 Python 包
export PYTHONNOUSERSITE=1
如果 Conda 未初始化：
source /home/ma-user/anaconda3/etc/profile.d/conda.sh
2. 创建 Paraformer 主环境
conda create -p $FUNASR_ROOT/envs/paraformer -y python=3.10
conda activate $FUNASR_ROOT/envs/paraformer

python -m pip install --upgrade pip setuptools wheel
先查看 GPU 驱动：
nvidia-smi
然后安装与服务器驱动匹配的 CUDA 版 PyTorch。服务器镜像已有正确 pip 源时可先尝试：
pip install torch torchaudio
